// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Better Auth Required Models ---

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions  Session[]
  accounts  Account[]
  auditLogs AuditLog[]

  // App-specific fields
  role         UserRole      @default(USER)
  status       UserStatus    @default(ACTIVE)
  ownerProfile HouseOwnerProfile?

  // Relations for tracking actions
  createdTaxRates      TaxRate[]           @relation("TaxRateCreatedBy")
  approvedTaxRates     TaxRate[]           @relation("TaxRateApprovedBy")
  issuedAssessments    TaxAssessment[]     @relation("AssessmentIssuedBy")
  approvedAssessments  TaxAssessment[]     @relation("AssessmentApprovedBy")
  cancelledAssessments TaxAssessment[]     @relation("AssessmentCancelledBy")
  verifiedPayments     Payment[]           @relation("PaymentVerifiedBy")
  issuedConfirmations  KebeleConfirmation[] @relation("ConfirmationIssuedBy")
  reviewedProperties   Property[]          @relation("PropertyReviewedBy")
  approvedProperties   Property[]          @relation("PropertyApprovedBy")
  reviewedDocuments    PropertyDocument[]  @relation("DocumentReviewedBy")

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// --- Enums ---

enum UserRole {
  ADMIN
  MANAGER
  ASSIGNED_WORKER
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum PropertyStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum OwnershipType {
  LEASE
  OLD_POSSESSION
  RENTAL
  OTHER
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AssessmentStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  ONLINE
  SINQEE_BANK
  CASH_MANUAL
  OTHER
}

enum PaymentStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
  CANCELLED
}

enum ConfirmationStatus {
  ISSUED
  CANCELLED
}

// --- App Domain Models ---

model HouseOwnerProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nationalId       String?
  kebeleIdNumber   String?
  fullName         String
  phone            String
  address          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  properties       Property[]
}

model Property {
  id                 String         @id @default(cuid())
  ownerId            String
  owner              HouseOwnerProfile @relation(fields: [ownerId], references: [id])
  houseNumber        String
  fileNumber         String
  landSizeKare       Decimal        @db.Decimal(10, 2)
  locationDescription String?
  locationCategoryId String?
  locationCategory   LocationCategory? @relation(fields: [locationCategoryId], references: [id])
  ownershipType      OwnershipType
  status             PropertyStatus @default(DRAFT)
  
  reviewedById       String?
  reviewedBy         User?          @relation("PropertyReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt         DateTime?
  approvedById       String?
  approvedBy         User?          @relation("PropertyApprovedBy", fields: [approvedById], references: [id])
  approvedAt         DateTime?
  rejectionReason    String?

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  documents          PropertyDocument[]
  assessments        TaxAssessment[]

  @@unique([houseNumber])
  @@unique([fileNumber])
}

model PropertyDocument {
  id             String         @id @default(cuid())
  propertyId     String
  property       Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  uploadedById   String
  title          String
  fileUrl        String
  fileName       String
  mimeType       String?
  documentType   String?
  note           String?
  fileSize       Int?
  status         DocumentStatus @default(PENDING)
  reviewedById   String?
  reviewedBy     User?          @relation("DocumentReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?
  rejectionReason String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model LocationCategory {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  properties  Property[]
  taxRates    TaxRate[]
}

model TaxRate {
  id                 String   @id @default(cuid())
  taxYear            Int
  locationCategoryId String
  locationCategory   LocationCategory @relation(fields: [locationCategoryId], references: [id])
  ratePerKare        Decimal  @db.Decimal(10, 2)
  penaltyType        String?  // e.g. "FIXED", "PERCENTAGE"
  penaltyValue       Decimal? @db.Decimal(10, 2)
  dueDate            DateTime?
  isActive           Boolean  @default(true)
  
  createdById        String
  createdBy          User     @relation("TaxRateCreatedBy", fields: [createdById], references: [id])
  approvedById       String?
  approvedBy         User?    @relation("TaxRateApprovedBy", fields: [approvedById], references: [id])
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  assessments        TaxAssessment[]

  @@unique([taxYear, locationCategoryId])
}

model TaxAssessment {
  id              String           @id @default(cuid())
  propertyId      String
  property        Property         @relation(fields: [propertyId], references: [id])
  taxRateId       String
  taxRate         TaxRate          @relation(fields: [taxRateId], references: [id])
  taxYear         Int
  landSizeKare    Decimal          @db.Decimal(10, 2)
  ratePerKare     Decimal          @db.Decimal(10, 2)
  baseAmount      Decimal          @db.Decimal(12, 2)
  penaltyAmount   Decimal          @default(0) @db.Decimal(12, 2)
  previousBalance Decimal          @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal          @db.Decimal(12, 2)
  status          AssessmentStatus @default(DRAFT)
  
  issuedById      String?
  issuedBy        User?            @relation("AssessmentIssuedBy", fields: [issuedById], references: [id])
  approvedById    String?
  approvedBy      User?            @relation("AssessmentApprovedBy", fields: [approvedById], references: [id])
  
  issuedAt        DateTime?
  dueDate         DateTime?
  note            String?
  
  cancelledById   String?
  cancelledBy     User?            @relation("AssessmentCancelledBy", fields: [cancelledById], references: [id])
  cancelledAt     DateTime?
  cancellationReason String?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  payments        Payment[]

  @@unique([propertyId, taxYear])
}

model Payment {
  id              String        @id @default(cuid())
  assessmentId    String
  assessment      TaxAssessment @relation(fields: [assessmentId], references: [id])
  payerId         String
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(12, 2)
  paidAt          DateTime?
  referenceNumber String?
  bankName        String?       @default("Sinqee Bank")
  bankBranch      String?
  receiptFileUrl  String?
  
  verifiedById    String?
  verifiedBy      User?         @relation("PaymentVerifiedBy", fields: [verifiedById], references: [id])
  
  verifiedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  confirmation    KebeleConfirmation?
}

model KebeleConfirmation {
  id                 String             @id @default(cuid())
  paymentId          String             @unique
  payment            Payment            @relation(fields: [paymentId], references: [id])
  confirmationNumber String             @unique
  status             ConfirmationStatus @default(ISSUED)
  
  issuedById         String
  issuedBy           User               @relation("ConfirmationIssuedBy", fields: [issuedById], references: [id])
  
  issuedAt           DateTime           @default(now())
  fileUrl            String?
  note               String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
